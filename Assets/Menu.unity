  Message: {fileID: 1982147609}
  delayMin: 1
  delayMax: 3
  showDuration: 2.5
  appearChance: 0.35
  mensagens:
  - text: "Esses Reinos n\xE3o foram feitos para voc\xEA."
    chance: 0.1
  - text: "Havia outra op\xE7\xE3o."
    chance: 0.1
  - text: "Esse n\xE3o \xE9 seu prop\xF3sito."
    chance: 0.08
  - text: "N\xE3o prossiga."
    chance: 0.08
  - text: "O teste n\xE3o \xE9 para voc\xEA."
    chance: 0.08
  - text: "Gelorum n\xE3o foi um exemplo bom o suficiente?"
    chance: 0.05
  - text: "Como pode ser uma de nossas cria\xE7\xF5es?"
    chance: 0.025
  - text: Decepcionante.
    chance: 0.08
